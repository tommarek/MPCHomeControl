            "zones": ["entrance", "ground_hall"],
            "area": 3.1875,
            "sub_boundaries": [
                { "boundary_type": "interior_door", "area": 1.89 }
            ]
        },
        {
            "boundary_type": "interior_wall_175",
            "zones": ["entrance", "ground_closet"],
            "area": 5.1
        },
        {
            "boundary_type": "interior_wall_175",
