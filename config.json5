{
    db: {
        //host: "http://192.168.0.201:8086",
        host: "http://localhost:8086",
        org: "loxone",
    },
    // Site location (central Europe) and heat-pump / comfort settings for the optimizer.
    site: {
        latitude: 49.494934,
        longitude: 17.390341,
        utc_offset_hours: 2,
        ground_temperature_c: 16.0, // slab/ground boundary temperature
    },
    heating: {
        // Direct electric (resistive) underfloor heating: 1 kWh electricity = 1 kWh heat, so the
        // "coefficient of performance" is 1.0 (no heat pump). max_heat_kw below is the electric load.
        cop: 1.0,
        comfort_penalty: 50.0,     // price-units per K per step of comfort-band violation
        // Underfloor-heated zones, ground + first floor (see model.json5 `ground_level_floor` / `first_level_floor`).
        // internal_gain_w: constant internal heat (occupants/appliances/cooking/fireplace) the
        // physics model has no source for. The ground-floor values were fitted by the winter active
        // backtest (non-negative least squares over Jan 2026: `backtest-heating`), which cut mean zone
        // RMSE 1.59 K -> 0.45 K. The first-floor zones don't set it yet (= 0, not yet fitted).
        // Re-fit if usage patterns change.
        zones: {
            entrance:        { max_heat_kw: 0.82, t_min: 18.0, t_max: 24.0 },  // zadveri
            ground_closet:   { max_heat_kw: 0.82, t_min: 18.0, t_max: 25.0 },  // satna_dole
            technical_room:  { max_heat_kw: 0.82, t_min: 18.0, t_max: 24.0, internal_gain_w: 39 },  // boiler/equipment standby
            ground_hall:     { max_heat_kw: 1.8, t_min: 20.0, t_max: 24.0, internal_gain_w: 56 },
            toilet:          { max_heat_kw: 0.22, t_min: 20.0, t_max: 24.0 },
            ground_bathroom: { max_heat_kw: 0.47, t_min: 20.0, t_max: 24.0 },
            livingroom:      { max_heat_kw: 3.0, t_min: 21.0, t_max: 24.0, internal_gain_w: 351 }, // fireplace + occupancy
            kitchen:         { max_heat_kw: 1.8, t_min: 21.0, t_max: 24.0, internal_gain_w: 261 }, // cooking + appliances
            storage:         { max_heat_kw: 0.46, t_min: 18.0, t_max: 25.0, internal_gain_w: 47 }, // spajz
            office:          { max_heat_kw: 0.82, t_min: 21.0, t_max: 24.0, internal_gain_w: 15 },  // occupant + PC
            // --- first floor ---
            first_floor_hall:     { max_heat_kw: 1.2,  t_min: 19.0, t_max: 25.0 }, // chodba nahore (landing)
            first_floor_bathroom: { max_heat_kw: 0.62, t_min: 20.0, t_max: 24.0 }, // bathroom
            first_floor_closet:   { max_heat_kw: 0.56, t_min: 18.0, t_max: 25.0 }, // satna (storage)
            bedroom:              { max_heat_kw: 1.2,  t_min: 20.0, t_max: 21.0 }, // loznice (master)
            room_1:               { max_heat_kw: 1.2,  t_min: 21.5, t_max: 22.5 }, // pokoj 1 (children)
            room_2:               { max_heat_kw: 1.2,  t_min: 18.0, t_max: 25.0 }, // pokoj 2 (unused)
            guestroom:            { max_heat_kw: 2.02, t_min: 18.0, t_max: 25.0 }, // hosti (unused)
        },
    },
    // Reversible HVAC / air-conditioning (PLANNED — not yet installed). Each unit injects/removes
    // heat at the AIR node of the zones it serves: cooling above `t_cool`, air-heating below
    // `t_heat`, co-existing with the underfloor heating. A unit serving one zone is a room split; a
    // unit serving several is a central/ducted system sharing one compressor's capacity. `cooling_cop`
    // / `heating_cop` are a constant OR a `[{ t, cop }]` curve vs outdoor °C (interpolated, clamped).
    // `units` is empty, so the feature is inert until a unit is added. See docs/configuration.md.
    hvac: {
        comfort_penalty: 50.0,         // price-units per K per step outside a room's [t_heat, t_cool] band
        comfort: {
            // Per-room deadband; air-heating holds >= t_heat, cooling holds <= t_cool (free-float between).
            // bedroom:    { t_heat: 20.0, t_cool: 26.0 },
            // room_1:     { t_heat: 20.0, t_cool: 26.0 },
            // livingroom: { t_heat: 20.0, t_cool: 26.0 },
        },
        units: {
            // A reversible split unit in one room:
            // bedroom_ac: {
            //     zones: ["bedroom"],
            //     max_cool_kw: 3.5, max_heat_kw: 3.5,
            //     cooling_cop: 3.0, heating_cop: 3.5,   // constant COPs
            // },
            // A central/ducted unit serving several rooms from one shared compressor:
            // upstairs_ducted: {
            //     zones: ["room_1", "livingroom"],
            //     max_cool_kw: 8.0, max_heat_kw: 9.0,                       // capacity SHARED across the rooms
            //     per_zone_max_kw: { room_1: 4.0, livingroom: 5.0 },        // optional per-room damper caps
            //     cooling_cop: [ { t: 25, cop: 3.6 }, { t: 35, cop: 2.3 } ], // COP curve vs outdoor °C
            //     heating_cop: [ { t: -10, cop: 2.0 }, { t: 7, cop: 3.5 }, { t: 15, cop: 4.6 } ],
            //     single_mode: true,    // ducted single compressor: heat OR cool the whole group per block
            // },
        },
    },
    // Real electricity tariff (Czech D57d / Growatt). OTE spot is EUR/MWh; fees are CZK/kWh,
    // converted with eur_czk_rate. Import = spot + distribution(VT/NT by local hour); export
    // (FVE buyback) = spot - sell_fee, no distribution. Mirrors loxone_smart_home.
    tariff: {
        eur_czk_rate: 25.0,
        distribution_high_czk: 0.919,   // VT: 0.755 distribution + 0.164 system services
        distribution_low_czk: 0.281,    // NT: 0.117 + 0.164
        low_tariff_hours: "0-10,11-12,13-14,15-17,18-24", // NT local-hour ranges (end exclusive)
        sell_fee_czk: 0.5,              // FVE buyback = OTE spot - 0.5 Kc/kWh (matches loxone)
        export_price_min_czk: 0.5,      // never export below this spot (revenue >= 0; = sell fee, matches loxone GROWATT_EXPORT_PRICE_MIN=0.5)
        battery_amortisation_czk: 1.0,  // battery wear per kWh discharged (matches loxone GROWATT_BATTERY_AMORTISATION_CZK=1.0)
        inverter_off_price_czk: -2.0,   // inverter off when spot below this (deeply negative)
    },
    // Home battery (Growatt) — capacity, SoC floor, charge/discharge power, round-trip efficiency.
    battery: {
        capacity_kwh: 10.0,
        min_soc_pct: 20.0,
        charge_kw: 5.3,
        discharge_kw: 5.3,
        round_trip_efficiency: 0.85,
    },
    // PV arrays — clear-sky fallback model (Solcast already covers both arrays when available).
    // Azimuths are the real panel bearings on the hip roof (a SW + a SE facet); they are independent
    // of model.json5's thermal roof, which approximates the whole roof as its two main NE/SW slopes.
    pv: {
        system_efficiency: 0.85,
        arrays: [
            { name: "terasa", kwp: 7.0, tilt: 35.0, azimuth: 226.0 }, // SW-facing roof
            { name: "ulice",  kwp: 6.5, tilt: 35.0, azimuth: 136.0 }, // SE-facing roof
        ],
    },
    // EV charger — the Loxone wallbox, detected exactly as loxone_smart_home's battery-protect logic
    // does: the `ev` measurement in the `loxone` bucket. `ev_connected` (1/0) is the authoritative
    // "on our wallbox" flag (loxone-side, so it respects "TeslaMate ≠ on our charger"); `ev_charging_power`
    // is the live charge power in kW. Car SoC comes from TeslaMate's Postgres (the `soc` source below,
    // DSN in $MPC_PG_TESLAMATE), so the charger is scheduled toward `target_pct` by `deadline` — not
    // just observed.
    chargers: [
        {
            name: "tesla",
            control: "modulating",     // loxone wallbox: the MPC can set rate + on/off (shadow only)
            max_kw: 11.0,              // 3-phase 16 A; adjust to your wallbox
            min_kw: 1.4,               // ~6 A single-phase floor
            efficiency: 0.9,
            battery_kwh: 75.0,         // car usable capacity; adjust to your model
            allow_battery_to_ev: false,
            strategy: "cost_optimized",
            target_pct: 80,
            deadline: "07:00",
            sources: {
                // ev_connected (1/0) — written on change, so it persists between events; the recency
                // guard means a long-idle car eventually reads "away" until the next event.
                on_charger: { type: "influx", bucket: "loxone", measurement: "ev", field: "ev_connected" },
                // ev_charging_power — already in kW (continuous), so scale stays 1.0.
                power: { type: "influx", bucket: "loxone", measurement: "ev", field: "ev_charging_power" },
                // Car SoC from TeslaMate's Postgres (DSN in $MPC_PG_TESLAMATE; teslamate-db is on
                // caddy_net). `car_id = 2` is "Tess" (this house has two cars; car 1 is the Y). The
                // union of positions + charges (joined via charging_processes) gives the freshest SoC:
                // seconds-fresh from `charges` during a charge, the last-known position otherwise (the
                // 30-day window bounds staleness). TeslaMate refreshes only while the car is online.
                soc: {
                    type: "postgres",
                    connection: "teslamate",
                    query: "select battery_level::float8 from (select date, battery_level from positions where car_id=2 union all select c.date, c.battery_level from charges c join charging_processes cp on c.charging_process_id=cp.id where cp.car_id=2) t where date > now() - interval '30 days' order by date desc limit 1",
                },
                // The car's own charge limit — TeslaMate publishes it only to MQTT (not Postgres), so
                // it comes via the read-only mqtt-source sidecar over HTTP (which subscribes Tess's
                // teslamate/cars/2/charge_limit_soc). Live preference and this override config target_pct.
                target: { type: "http", url: "http://mpc-mqtt-source:8088/v1/value/ev_target", pointer: "/value" },
                // Usable battery capacity (kWh) DERIVED from TeslaMate's charge history rather than
                // guessed: charge_energy_added / SoC-delta, averaged over the last 20 substantial
                // charges (≈58 kWh for Tess, vs the 75 battery_kwh fallback). Overrides battery_kwh.
                capacity: {
                    type: "postgres",
                    connection: "teslamate",
                    query: "select avg(cap)::float8 from (select charge_energy_added/((end_battery_level-start_battery_level)/100.0) as cap from charging_processes where car_id=2 and end_battery_level > start_battery_level + 10 and charge_energy_added > 5 order by start_date desc limit 20) t",
                },
            },
        },
    ],
    consumption_history_days: 30,   // trailing window for training the consumption model
    mpc_tick_minutes: 1,            // recompute every minute from fresh state (temps, SoC)
    zone_mappings: {
        entrance: { // zone name
            temperature: { // measurement type
                bucket: "loxone", // bucket
                measurement: "temperature",
                tags: {
                    room: "zadveri",
                },
                field: "temperature_zadveri"
            }
        },
        ground_closet: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "satna_dole",
                },
                field: "temperature_satna_dole",
            }
        },
        technical_room: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "technicka_mistnost",
                },
                field: "temperature_technicka_mistnost",
            }
        },
        ground_hall: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "chodba_dole",
                },
                field: "temperature_chodba_dole",
            }
        },
        toilet: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "zachod",
                },
                field: "temperature_zachod",
            }
        },
        ground_bathroom: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "koupelna_dole",
                },
                field: "temperature_koupelna_dole",
            }
        },
        livingroom: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "obyvak",
                },
                field: "temperature_obyvak",
            }
        },
        kitchen: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "kuchyne",
                },
                field: "temperature_kuchyne",
            }
        },
        storage: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "spajz",
                },
                field: "temperature_spajz",
            }
        },
        office: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "pracovna",
                },
                field: "temperature_pracovna",
            }
        },
        first_floor_closet: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "satna_nahore",
                },
                field: "temperature_satna_nahore",
            }
        },
        first_floor_bathroom: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "koupelna_nahore",
                },
                field: "temperature_koupelna_nahore",
            }
        },
        bedroom: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "loznice",
                },
                field: "temperature_loznice",
            }
        },
        room_1: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "pokoj_1",
                },
                field: "temperature_pokoj_1",
            }
        },
        room_2: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "pokoj_2",
                },
                field: "temperature_pokoj_2",
            }
        },
        first_floor_hall: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "chodba_nahore",
                },
                field: "temperature_chodba_nahore",
            }
        },
        guestroom: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "hosti",
                },
                field: "temperature_hosti",
            }
        },
        garrage: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "garaz",
                },
                field: "temperature_garaz",
            }
        },
        attic: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "puda",
                },
                field: "temperature_puda",
            }
        },
        outside: {
            temperature: {
                // Measured outside air temp from the solar/teplomer weather station. The loxone
                // `venek` sensor is sun-exposed (spikes to ~44 °C in the morning sun), so use the
                // teplomer/TC reading (clean diurnal curve, matches the dew-point/RH it reports).
                bucket: "solar",
                measurement: "teplomer",
                tags: {
                    topic: "teplomer/TC",
                },
                field: "value"
            }
        },
    },
    // Per-house source overrides for signals whose default locator doesn't match this house's data
    // pipeline. Curtailment detection: the inverter's export flag lives in `inverter_state`
    // (loxone-written) and battery SoC in the grott `solar` telemetry as `SOC` — the generic
    // `solar/solar/{export_enabled,battery_soc}` defaults return zero rows here.
    data_sources: {
        curtailment_export: { type: "influx", bucket: "solar", measurement: "inverter_state", field: "export_enabled" },
        curtailment_soc: { type: "influx", bucket: "solar", measurement: "solar", field: "SOC" },
    },
}