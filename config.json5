                },
                field: "temperature_pokoj_2",
            }
        },
        first_floor_hall: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "chodba_nahore",
                },
                field: "temperature_chodba_nahore",
            }
        },
        guestroom: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "hosti",
                },
                field: "temperature_hosti",
            }
        },
        garrage: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "garaz",
                },
                field: "temperature_garaz",
            }
        },
        attic: {
            temperature: {
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "puda",
                },
                field: "temperature_puda",
            }
        },
        outside: {
            temperature: {
                // Measured outside air-temperature sensor (not the open-meteo forecast).
                bucket: "loxone",
                measurement: "temperature",
                tags: {
                    room: "venek",
                },
                field: "temperature_outside"
            }
        },
    }
}