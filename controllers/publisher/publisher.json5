{
    // Armed in production (publishes plan-derived commands to the inert mpc/control/... MQTT namespace;
    // the per-domain controllers below apply their own two-key gate before any device is touched).
    armed: true,
    // The MPC's read-only plan endpoint to poll.
    mpc_url: "http://127.0.0.1:3000/api/plan/latest",
    poll_seconds: 30,
    // Each command is valid for now + this; a stalled publisher hands control back (deadman).
    deadman_seconds: 120,
    mqtt: { host: "127.0.0.1", port: 1883, client_id: "mpc-plan-publisher" },
    // Emit a battery command for the Growatt controller (SoC band the controller pins against).
    battery: { controller_id: "growatt", min_soc_kwh: 2.0, max_soc_kwh: 10.0 },
    // The unified Loxone controller — SUPERSEDES the `heating` + `ev` blocks (loading both is
    // rejected). Maps each plan field to its exact Loxone virtual-input key. The MPCActive gate is
    // configured in controllers/loxone/loxone.json5, NOT here. See docs/controllers.md for the
    // Loxone-side wiring (digital-input pulse → Off-Delay watchdog).
    loxone: {
        controller_id: "loxone",
        heating: {
            on_threshold_kw: 0.05,
            // MPC zone (English) -> Loxone virtual input (MPCHeat<Czech room, CamelCase>), one per
            // relay-heated room. The first-floor rooms stay dormant until their model.json5 floor
            // boundaries (heating markers) are added.
            zone_keys: {
                entrance:             "MPCHeatZadveri",
                ground_closet:        "MPCHeatSatnaDole",
                technical_room:       "MPCHeatTechnickaMistnost",
                ground_hall:          "MPCHeatChodbaDole",
                toilet:               "MPCHeatZachod",
                ground_bathroom:      "MPCHeatKoupelnaDole",
                livingroom:           "MPCHeatObyvak",
                kitchen:              "MPCHeatKuchyne",
                storage:              "MPCHeatSpajz",
                office:               "MPCHeatPracovna",
                first_floor_hall:     "MPCHeatChodbaNahore",
                first_floor_bathroom: "MPCHeatKoupelnaNahore",
                first_floor_closet:   "MPCHeatSatnaNahore",
                bedroom:              "MPCHeatLoznice",
                room_1:               "MPCHeatPokoj1",
                room_2:               "MPCHeatPokoj2",
                guestroom:            "MPCHeatHosti",
            },
        },
        ev: { power_key: "EvChargePower" },
    },

    // Superseded by the unified `loxone` block above — do NOT enable alongside it (the publisher
    // rejects configuring both):
    // heating: { controller_id: "heating", on_threshold_kw: 0.05 },
    // ev:      { controller_id: "ev", on_threshold_kw: 0.05 },
}
